{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://plugins.dprint.dev/kjanat/dprint-plugin-svg/0.1.0/schema.json",
	"title": "Top-level configuration schema for the dprint SVG plugin.",
	"description": "All fields are optional — omitted values fall back to dprint global\nconfig or built-in defaults.",
	"type": "object",
	"properties": {
		"attributeLayout": {
			"description": "Attribute line-breaking strategy.",
			"anyOf": [
				{
					"$ref": "#/definitions/AttributeLayoutConfig"
				},
				{
					"type": "null"
				}
			]
		},
		"attributeSort": {
			"description": "Attribute ordering strategy.",
			"anyOf": [
				{
					"$ref": "#/definitions/AttributeSortConfig"
				},
				{
					"type": "null"
				}
			]
		},
		"attributesPerLine": {
			"description": "Maximum number of attributes per line in multi-line mode.",
			"type": [
				"integer",
				"null"
			],
			"format": "uint32",
			"minimum": 1
		},
		"indentWidth": {
			"description": "Indent width when useTabs is false.",
			"type": [
				"integer",
				"null"
			],
			"format": "uint8",
			"minimum": 1,
			"maximum": 255
		},
		"lineWidth": {
			"description": "Fallback line width for formatting decisions when maxInlineTagWidth is\nnot provided.",
			"type": [
				"integer",
				"null"
			],
			"format": "uint32",
			"minimum": 1
		},
		"locked": {
			"description": "Whether the configuration is not allowed to be overridden or extended.",
			"type": [
				"boolean",
				"null"
			]
		},
		"maxInlineTagWidth": {
			"description": "Maximum inline tag width before wrapping attributes or children.",
			"type": [
				"integer",
				"null"
			],
			"format": "uint32",
			"minimum": 1
		},
		"newLineKind": {
			"description": "The newline kind to write.",
			"anyOf": [
				{
					"$ref": "#/definitions/NewLineKindConfig"
				},
				{
					"type": "null"
				}
			]
		},
		"quoteStyle": {
			"description": "Quote style for attribute values.",
			"anyOf": [
				{
					"$ref": "#/definitions/QuoteStyleConfig"
				},
				{
					"type": "null"
				}
			]
		},
		"spaceBeforeSelfClose": {
			"description": "Whether to include a space before '/>' in self-closing tags.",
			"type": [
				"boolean",
				"null"
			]
		},
		"useTabs": {
			"description": "Use tabs for indentation instead of spaces.",
			"type": [
				"boolean",
				"null"
			]
		},
		"wrappedAttributeIndent": {
			"description": "Indent style for wrapped attributes.",
			"anyOf": [
				{
					"$ref": "#/definitions/WrappedAttributeIndentConfig"
				},
				{
					"type": "null"
				}
			]
		}
	},
	"definitions": {
		"AttributeLayoutConfig": {
			"type": "string",
			"enum": [
				"auto",
				"single-line",
				"multi-line"
			]
		},
		"AttributeSortConfig": {
			"type": "string",
			"enum": [
				"none",
				"canonical",
				"alphabetical"
			]
		},
		"NewLineKindConfig": {
			"type": "string",
			"enum": [
				"auto",
				"lf",
				"crlf"
			]
		},
		"QuoteStyleConfig": {
			"type": "string",
			"enum": [
				"preserve",
				"double",
				"single"
			]
		},
		"WrappedAttributeIndentConfig": {
			"type": "string",
			"enum": [
				"one-level",
				"align-to-tag-name"
			]
		}
	}
}
